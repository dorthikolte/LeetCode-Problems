class Solution {
    public int magicalString(int n) {
        if (n <= 0) return 0;
        if (n <= 3) return 1;

        int[] s = new int[n + 2]; // extra space
        s[0] = 1;
        s[1] = 2;
        s[2] = 2;

        int count = 1; // we already have one '1'
        int i = 2;     // pointer for reading counts
        int j = 3;     // pointer for writing
        int num = 1;   // next number to insert

        while (j < n) {
            int times = s[i];

            for (int k = 0; k < times && j < n; k++) {
                s[j] = num;
                if (num == 1) count++;
                j++;
            }

            num = 3 - num; // toggle between 1 and 2
            i++;
        }

        return count;
    }
}
