class Solution {
    public int nextGreaterElement(int n) {
        char[] arr = String.valueOf(n).toCharArray();
        int len = arr.length;

        // Find the pivot
        int i = len - 2;
        while (i >= 0 && arr[i] >= arr[i + 1]) {
            i--;
        }

        // No greater permutation exists
        if (i < 0) return -1;

        // Find the smallest digit greater than arr[i]
        int j = len - 1;
        while (arr[j] <= arr[i]) {
            j--;
        }

        // Swap
        char temp = arr[i];
        arr[i] = arr[j];
        arr[j] = temp;

        // Reverse the suffix
        reverse(arr, i + 1, len - 1);

        // Check overflow
        long ans = Long.parseLong(new String(arr));
        return ans > Integer.MAX_VALUE ? -1 : (int) ans;
    }

    private void reverse(char[] arr, int l, int r) {
        while (l < r) {
            char temp = arr[l];
            arr[l] = arr[r];
            arr[r] = temp;
            l++;
            r--;
        }
    }
}
