import java.util.*;

class SummaryRanges {

    private TreeMap<Integer, Integer> map;

    public SummaryRanges() {
        map = new TreeMap<>();
    }

    public void addNum(int value) {

        if (map.containsKey(value))
            return;

        Integer lowerKey = map.floorKey(value);
        Integer higherKey = map.ceilingKey(value);

        int start = value;
        int end = value;

        // Merge with left interval
        if (lowerKey != null && map.get(lowerKey) + 1 >= value) {
            start = lowerKey;
            end = Math.max(end, map.get(lowerKey));
            map.remove(lowerKey);
        }

        // Merge with right interval
        if (higherKey != null && higherKey - 1 <= end) {
            end = Math.max(end, map.get(higherKey));
            map.remove(higherKey);
        }

        map.put(start, end);
    }

    public int[][] getIntervals() {

        int[][] res = new int[map.size()][2];
        int i = 0;

        for (Map.Entry<Integer, Integer> entry : map.entrySet()) {
            res[i][0] = entry.getKey();
            res[i][1] = entry.getValue();
            i++;
        }

        return res;
    }
}
