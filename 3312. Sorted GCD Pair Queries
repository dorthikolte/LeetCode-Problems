class Solution {
    public int[] gcdValues(int[] nums, long[] queries) {
        int max = 0;
        for (int x : nums) max = Math.max(max, x);

        int[] freq = new int[max + 1];
        for (int x : nums) freq[x]++;

        int[] divCnt = new int[max + 1];

        // Count numbers divisible by each g
        for (int g = 1; g <= max; g++) {
            for (int m = g; m <= max; m += g) {
                divCnt[g] += freq[m];
            }
        }

        long[] exact = new long[max + 1];

        // Inclusion-exclusion to get exact gcd counts
        for (int g = max; g >= 1; g--) {
            long pairs = (long) divCnt[g] * (divCnt[g] - 1) / 2;
            for (int m = g + g; m <= max; m += g) {
                pairs -= exact[m];
            }
            exact[g] = pairs;
        }

        // Prefix sums
        long[] prefix = new long[max + 1];
        for (int g = 1; g <= max; g++) {
            prefix[g] = prefix[g - 1] + exact[g];
        }

        int[] ans = new int[queries.length];

        // Binary search for each query
        for (int i = 0; i < queries.length; i++) {
            long target = queries[i] + 1; // 0-based index
            int lo = 1, hi = max;
            while (lo < hi) {
                int mid = (lo + hi) >>> 1;
                if (prefix[mid] >= target)
                    hi = mid;
                else
                    lo = mid + 1;
            }
            ans[i] = lo;
        }

        return ans;
    }
}
