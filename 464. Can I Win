import java.util.*;

class Solution {
    public boolean canIWin(int maxChoosableInteger, int desiredTotal) {
        // Edge case
        if (desiredTotal <= 0) return true;

        int sum = (maxChoosableInteger * (maxChoosableInteger + 1)) / 2;

        // If total sum is less than desiredTotal → impossible
        if (sum < desiredTotal) return false;

        Map<Integer, Boolean> memo = new HashMap<>();

        return dfs(0, desiredTotal, maxChoosableInteger, memo);
    }

    private boolean dfs(int usedMask, int remaining, int max, Map<Integer, Boolean> memo) {
        if (memo.containsKey(usedMask)) {
            return memo.get(usedMask);
        }

        for (int i = 1; i <= max; i++) {
            int bit = 1 << (i - 1);

            // if number i is unused
            if ((usedMask & bit) == 0) {

                // if picking i wins immediately OR opponent loses
                if (i >= remaining || 
                    !dfs(usedMask | bit, remaining - i, max, memo)) {

                    memo.put(usedMask, true);
                    return true;
                }
            }
        }

        memo.put(usedMask, false);
        return false;
    }
}
