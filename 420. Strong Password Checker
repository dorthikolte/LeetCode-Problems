class Solution {
    public int strongPasswordChecker(String password) {
        int n = password.length();
        
        // Check missing types
        boolean hasLower = false, hasUpper = false, hasDigit = false;
        for (char c : password.toCharArray()) {
            if (Character.isLowerCase(c)) hasLower = true;
            else if (Character.isUpperCase(c)) hasUpper = true;
            else if (Character.isDigit(c)) hasDigit = true;
        }
        int missingTypes = 0;
        if (!hasLower) missingTypes++;
        if (!hasUpper) missingTypes++;
        if (!hasDigit) missingTypes++;
        
        // Count repeating sequences
        int replace = 0;
        int[] repeats = new int[n];
        
        for (int i = 0; i < n;) {
            int j = i;
            while (i < n && password.charAt(i) == password.charAt(j)) i++;
            repeats[j] = i - j;
        }
        
        if (n < 6) {
            return Math.max(missingTypes, 6 - n);
        }
        
        // Count replacements needed
        for (int len : repeats) {
            if (len >= 3) {
                replace += len / 3;
            }
        }
        
        if (n <= 20) {
            return Math.max(missingTypes, replace);
        }
        
        // Too long → need deletions
        int delete = n - 20;
        int remainingDelete = delete;
        
        // Optimize deletions to reduce replacements
        for (int k = 1; k <= 2; k++) {
            for (int i = 0; i < n && remainingDelete > 0; i++) {
                if (repeats[i] < 3 || repeats[i] % 3 != (k - 1)) continue;
                
                int needed = Math.min(remainingDelete, k);
                repeats[i] -= needed;
                remainingDelete -= needed;
            }
        }
        
        // Apply remaining deletions
        for (int i = 0; i < n && remainingDelete > 0; i++) {
            if (repeats[i] >= 3) {
                int needed = repeats[i] - 2;
                int used = Math.min(needed, remainingDelete);
                repeats[i] -= used;
                remainingDelete -= used;
            }
        }
        
        // Recalculate replacements
        replace = 0;
        for (int len : repeats) {
            if (len >= 3) {
                replace += len / 3;
            }
        }
        
        return delete + Math.max(missingTypes, replace);
    }
}
