class Solution {
    public int maximumLength(int[] nums) {
        Map<Long, Integer> cnt = new HashMap<>();
        for (int x : nums) {
            cnt.put((long)x, cnt.getOrDefault((long)x, 0) + 1);
        }

        int ans = 1;

        // handle 1 separately
        if (cnt.containsKey(1L)) {
            int c = cnt.get(1L);
            ans = Math.max(ans, (c % 2 == 1) ? c : c - 1);
        }

        for (long x : cnt.keySet()) {
            if (x == 1) continue;

            long cur = x;
            int len = 0;

            while (true) {
                int c = cnt.getOrDefault(cur, 0);

                if (c == 0) {
                    len--;          // remove the last pair
                    break;
                }

                if (c == 1) {
                    len++;          // use as center
                    break;
                }

                // c >= 2
                len += 2;           // use this value on both sides

                if (cur > 1000000000L / cur) {
                    len--;          // cannot continue, so last pair becomes invalid
                    break;
                }

                long nxt = cur * cur;
                if (!cnt.containsKey(nxt)) {
                    len--;          // no center above, remove last pair
                    break;
                }

                cur = nxt;
            }

            ans = Math.max(ans, len);
        }

        return ans;
    }
}
