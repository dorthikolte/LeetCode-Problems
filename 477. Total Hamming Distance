class Solution {
    public int totalHammingDistance(int[] nums) {
        int total = 0;
        int n = nums.length;
        
        // Check all 32 bit positions
        for (int i = 0; i < 32; i++) {
            int ones = 0;
            
            // Count how many numbers have the i-th bit set
            for (int num : nums) {
                if (((num >> i) & 1) == 1) {
                    ones++;
                }
            }
            
            int zeros = n - ones;
            total += ones * zeros;
        }
        
        return total;
    }
}
