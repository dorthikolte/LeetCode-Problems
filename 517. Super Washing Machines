class Solution {
    public int findMinMoves(int[] machines) {
        int n = machines.length;
        int total = 0;

        for (int m : machines) {
            total += m;
        }

        if (total % n != 0) {
            return -1;
        }

        int avg = total / n;
        int balance = 0;
        int ans = 0;

        for (int m : machines) {
            int diff = m - avg;
            balance += diff;

            ans = Math.max(ans, Math.max(Math.abs(balance), diff));
        }

        return ans;
    }
}
