class Solution {
    public boolean checkRecord(String s) {
        int absent = 0;
        int late = 0;

        for (char ch : s.toCharArray()) {
            if (ch == 'A') {
                absent++;
                if (absent >= 2) return false;
                late = 0;
            } 
            else if (ch == 'L') {
                late++;
                if (late >= 3) return false;
            } 
            else { // 'P'
                late = 0;
            }
        }

        return true;
    }
}
