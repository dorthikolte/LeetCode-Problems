class Solution {
    public boolean circularArrayLoop(int[] nums) {
        int n = nums.length;

        for (int i = 0; i < n; i++) {
            if (nums[i] == 0) continue;

            int slow = i;
            int fast = i;
            boolean forward = nums[i] > 0;

            while (true) {
                slow = nextIndex(nums, slow);
                fast = nextIndex(nums, fast);
                
                // check direction for fast (1st move)
                if (nums[fast] == 0 || (nums[fast] > 0) != forward) break;
                
                fast = nextIndex(nums, fast);
                
                // check direction for fast (2nd move)
                if (nums[fast] == 0 || (nums[fast] > 0) != forward) break;

                // check direction for slow
                if (nums[slow] == 0 || (nums[slow] > 0) != forward) break;

                if (slow == fast) {
                    // check cycle length > 1
                    if (slow == nextIndex(nums, slow)) break;
                    return true;
                }
            }

            // mark visited nodes as 0
            int curr = i;
            int direction = nums[i];

            while (nums[curr] != 0 && (nums[curr] > 0) == (direction > 0)) {
                int next = nextIndex(nums, curr);
                nums[curr] = 0; // mark visited
                curr = next;
            }
        }

        return false;
    }

    private int nextIndex(int[] nums, int i) {
        int n = nums.length;
        return ((i + nums[i]) % n + n) % n;
    }
}
