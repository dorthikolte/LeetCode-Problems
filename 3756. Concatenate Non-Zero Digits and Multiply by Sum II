class Solution {
    static final int MOD = 1_000_000_007;

    public int[] sumAndMultiply(String s, int[][] queries) {
        int m = s.length();

        // Collect all non-zero digits and their positions.
        int cnt = 0;
        for (int i = 0; i < m; i++) {
            if (s.charAt(i) != '0') cnt++;
        }

        int[] pos = new int[cnt];
        int[] digit = new int[cnt + 1]; // 1-indexed
        int idx = 0;
        for (int i = 0; i < m; i++) {
            char c = s.charAt(i);
            if (c != '0') {
                pos[idx] = i;
                digit[idx + 1] = c - '0';
                idx++;
            }
        }

        long[] pow10 = new long[cnt + 1];
        long[] prefVal = new long[cnt + 1];
        int[] prefSum = new int[cnt + 1];

        pow10[0] = 1;
        for (int i = 1; i <= cnt; i++) {
            pow10[i] = (pow10[i - 1] * 10) % MOD;
            prefVal[i] = (prefVal[i - 1] * 10 + digit[i]) % MOD;
            prefSum[i] = prefSum[i - 1] + digit[i];
        }

        int[] ans = new int[queries.length];

        for (int i = 0; i < queries.length; i++) {
            int l = queries[i][0];
            int r = queries[i][1];

            int left0 = lowerBound(pos, l);
            int right0 = upperBound(pos, r) - 1;

            if (left0 > right0) {
                ans[i] = 0;
                continue;
            }

            int L = left0 + 1;   // convert to 1-indexed
            int R = right0 + 1;

            int len = R - L + 1;
            long x = (prefVal[R] - (prefVal[L - 1] * pow10[len]) % MOD + MOD) % MOD;
            long sum = prefSum[R] - prefSum[L - 1];

            ans[i] = (int) ((x * (sum % MOD)) % MOD);
        }

        return ans;
    }

    private int lowerBound(int[] arr, int target) {
        int lo = 0, hi = arr.length;
        while (lo < hi) {
            int mid = (lo + hi) >>> 1;
            if (arr[mid] < target) lo = mid + 1;
            else hi = mid;
        }
        return lo;
    }

    private int upperBound(int[] arr, int target) {
        int lo = 0, hi = arr.length;
        while (lo < hi) {
            int mid = (lo + hi) >>> 1;
            if (arr[mid] <= target) lo = mid + 1;
            else hi = mid;
        }
        return lo;
    }
}
