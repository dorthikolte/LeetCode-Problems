import java.util.*;

class Solution {
    public double[] medianSlidingWindow(int[] nums, int k) {
        DualHeap dh = new DualHeap(k);
        double[] res = new double[nums.length - k + 1];

        // Initialize first window
        for (int i = 0; i < k; i++) {
            dh.insert(nums[i]);
        }
        res[0] = dh.getMedian();

        // Slide the window
        for (int i = k; i < nums.length; i++) {
            dh.insert(nums[i]);
            dh.erase(nums[i - k]);
            res[i - k + 1] = dh.getMedian();
        }

        return res;
    }
}

class DualHeap {
    // Max heap (stores smaller half)
    private PriorityQueue<Integer> small;

    // Min heap (stores larger half)
    private PriorityQueue<Integer> large;

    // Lazy deletion map
    private Map<Integer, Integer> delayed;

    private int k;
    private int smallSize, largeSize;

    public DualHeap(int k) {
        this.k = k;

        // ✅ FIX: safe comparator (prevents overflow)
        small = new PriorityQueue<>((a, b) -> Integer.compare(b, a));

        large = new PriorityQueue<>();
        delayed = new HashMap<>();
        smallSize = 0;
        largeSize = 0;
    }

    public double getMedian() {
        if ((k & 1) == 1) {
            return small.peek();
        }
        return ((long) small.peek() + large.peek()) / 2.0;
    }

    public void insert(int num) {
        if (small.isEmpty() || num <= small.peek()) {
            small.offer(num);
            smallSize++;
        } else {
            large.offer(num);
            largeSize++;
        }
        makeBalance();
    }

    public void erase(int num) {
        delayed.put(num, delayed.getOrDefault(num, 0) + 1);

        if (num <= small.peek()) {
            smallSize--;
            if (num == small.peek()) {
                prune(small);
            }
        } else {
            largeSize--;
            if (num == large.peek()) {
                prune(large);
            }
        }

        makeBalance();
    }

    private void prune(PriorityQueue<Integer> heap) {
        while (!heap.isEmpty()) {
            int num = heap.peek();
            if (delayed.containsKey(num)) {
                delayed.put(num, delayed.get(num) - 1);
                if (delayed.get(num) == 0) {
                    delayed.remove(num);
                }
                heap.poll();
            } else {
                break;
            }
        }
    }

    private void makeBalance() {
        // Ensure size property: small >= large and diff <= 1
        if (smallSize > largeSize + 1) {
            large.offer(small.poll());
            smallSize--;
            largeSize++;
            prune(small);
        } else if (smallSize < largeSize) {
            small.offer(large.poll());
            smallSize++;
            largeSize--;
            prune(large);
        }
    }
}
