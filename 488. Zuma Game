import java.util.*;

class Solution {
    public int findMinStep(String board, String hand) {
        char[] handArr = hand.toCharArray();
        Arrays.sort(handArr);
        boolean[] used = new boolean[handArr.length];

        int res = dfs(board, handArr, used);
        return res == Integer.MAX_VALUE ? -1 : res;
    }

    private int dfs(String board, char[] hand, boolean[] used) {
        board = shrink(board);
        if (board.length() == 0) return 0;

        int ans = Integer.MAX_VALUE;

        for (int i = 0; i <= board.length(); i++) {
            for (int j = 0; j < hand.length; j++) {
                if (used[j]) continue;

                // skip duplicates in hand
                if (j > 0 && hand[j] == hand[j - 1] && !used[j - 1]) continue;

                // pruning: only insert if useful
                if (i > 0 && board.charAt(i - 1) == hand[j]) continue;
                if (i < board.length() && board.charAt(i) == hand[j]
                        || (i > 0 && i < board.length()
                        && board.charAt(i - 1) == board.charAt(i)
                        && board.charAt(i - 1) != hand[j])) {

                    used[j] = true;

                    String newBoard = board.substring(0, i) + hand[j] + board.substring(i);
                    int next = dfs(newBoard, hand, used);

                    if (next != Integer.MAX_VALUE) {
                        ans = Math.min(ans, next + 1);
                    }

                    used[j] = false;
                }
            }
        }

        return ans;
    }

    private String shrink(String board) {
        int i = 0;
        while (i < board.length()) {
            int j = i;
            while (j < board.length() && board.charAt(j) == board.charAt(i)) j++;

            if (j - i >= 3) {
                return shrink(board.substring(0, i) + board.substring(j));
            }
            i = j;
        }
        return board;
    }
}
