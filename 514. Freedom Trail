class Solution {

    public int findRotateSteps(String ring, String key) {
        int n = ring.length();

        // Store positions of each character in ring
        Map<Character, List<Integer>> map = new HashMap<>();

        for (int i = 0; i < n; i++) {
            map.computeIfAbsent(ring.charAt(i), k -> new ArrayList<>()).add(i);
        }

        // memo[index in key][current ring position]
        Integer[][] memo = new Integer[key.length()][n];

        return dfs(0, 0, ring, key, map, memo);
    }

    private int dfs(int keyIndex, int ringPos,
                    String ring, String key,
                    Map<Character, List<Integer>> map,
                    Integer[][] memo) {

        // All characters processed
        if (keyIndex == key.length()) {
            return 0;
        }

        if (memo[keyIndex][ringPos] != null) {
            return memo[keyIndex][ringPos];
        }

        int n = ring.length();
        int minSteps = Integer.MAX_VALUE;

        char target = key.charAt(keyIndex);

        // Try every occurrence of target character
        for (int nextPos : map.get(target)) {

            int clockwise = Math.abs(nextPos - ringPos);
            int anticlockwise = n - clockwise;

            int rotateSteps = Math.min(clockwise, anticlockwise);

            // +1 for pressing the button
            int total = rotateSteps + 1 +
                    dfs(keyIndex + 1, nextPos, ring, key, map, memo);

            minSteps = Math.min(minSteps, total);
        }

        return memo[keyIndex][ringPos] = minSteps;
    }
}
