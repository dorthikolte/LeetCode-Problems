class Solution {

    private int[][] directions = {
        {1, 0}, {-1, 0}, {0, 1}, {0, -1}
    };

    public int longestIncreasingPath(int[][] matrix) {

        int m = matrix.length;
        int n = matrix[0].length;

        // dp[i][j] stores longest path starting from (i,j)
        int[][] dp = new int[m][n];

        int maxLength = 0;

        for (int i = 0; i < m; i++) {
            for (int j = 0; j < n; j++) {
                maxLength = Math.max(maxLength,
                        dfs(matrix, i, j, dp));
            }
        }

        return maxLength;
    }

    private int dfs(int[][] matrix, int r, int c, int[][] dp) {

        // already computed
        if (dp[r][c] != 0)
            return dp[r][c];

        int m = matrix.length;
        int n = matrix[0].length;

        int max = 1; // path includes current cell

        for (int[] dir : directions) {
            int nr = r + dir[0];
            int nc = c + dir[1];

            // check bounds + increasing condition
            if (nr >= 0 && nr < m && nc >= 0 && nc < n
                    && matrix[nr][nc] > matrix[r][c]) {

                int length = 1 + dfs(matrix, nr, nc, dp);
                max = Math.max(max, length);
            }
        }

        dp[r][c] = max; // memoize
        return max;
    }
}
