class Solution {
    public int findNthDigit(int n) {
        long digit = 1;
        long count = 9;
        long start = 1;

        // Find the block where the nth digit belongs
        while (n > digit * count) {
            n -= digit * count;
            digit++;
            count *= 10;
            start *= 10;
        }

        // Find the actual number
        long num = start + (n - 1) / digit;

        // Convert to string and find the digit
        String s = Long.toString(num);
        return s.charAt((n - 1) % (int)digit) - '0';
    }
}
