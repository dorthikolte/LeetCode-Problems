class Solution {
    public int hammingDistance(int x, int y) {
        int xor = x ^ y;  // Step 1: find differing bits
        int count = 0;
        
        // Step 2: count number of 1s
        while (xor != 0) {
            count += xor & 1;  // check last bit
            xor >>= 1;         // shift right
        }
        
        return count;
    }
}
