class Solution {
    public int longestPalindrome(String s) {
        int[] freq = new int[128]; // ASCII
        
        // Count frequencies
        for (char c : s.toCharArray()) {
            freq[c]++;
        }
        
        int length = 0;
        boolean hasOdd = false;
        
        for (int count : freq) {
            length += (count / 2) * 2; // take even part
            
            if (count % 2 == 1) {
                hasOdd = true;
            }
        }
        
        // Add one odd character in center if possible
        if (hasOdd) length += 1;
        
        return length;
    }
}
