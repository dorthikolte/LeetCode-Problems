class Solution {
    public int lengthLongestPath(String input) {
        String[] parts = input.split("\n");
        int[] depthLength = new int[parts.length + 1];
        int maxLen = 0;

        for (String part : parts) {
            int depth = part.lastIndexOf("\t") + 1;
            String name = part.substring(depth);

            if (name.contains(".")) {
                maxLen = Math.max(maxLen, depthLength[depth] + name.length());
            } else {
                depthLength[depth + 1] = depthLength[depth] + name.length() + 1;
            }
        }

        return maxLen;
    }
}
