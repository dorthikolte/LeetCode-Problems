class Solution {
    static final int MOD = 1_000_000_007;
    static final int MAX = 200;

    public int subsequencePairCount(int[] nums) {
        int[][] gcd = new int[MAX + 1][MAX + 1];
        for (int i = 0; i <= MAX; i++) {
            for (int j = 0; j <= MAX; j++) {
                if (i == 0) gcd[i][j] = j;
                else if (j == 0) gcd[i][j] = i;
                else gcd[i][j] = gcd(i, j);
            }
        }

        long[][] dp = new long[MAX + 1][MAX + 1];
        dp[0][0] = 1;

        for (int x : nums) {
            long[][] ndp = new long[MAX + 1][MAX + 1];

            for (int g1 = 0; g1 <= MAX; g1++) {
                for (int g2 = 0; g2 <= MAX; g2++) {
                    long cur = dp[g1][g2];
                    if (cur == 0) continue;

                    // Skip
                    ndp[g1][g2] = (ndp[g1][g2] + cur) % MOD;

                    // Put into seq1
                    int ng1 = gcd[g1][x];
                    ndp[ng1][g2] = (ndp[ng1][g2] + cur) % MOD;

                    // Put into seq2
                    int ng2 = gcd[g2][x];
                    ndp[g1][ng2] = (ndp[g1][ng2] + cur) % MOD;
                }
            }
            dp = ndp;
        }

        long ans = 0;
        for (int g = 1; g <= MAX; g++) {
            ans = (ans + dp[g][g]) % MOD;
        }
        return (int) ans;
    }

    private int gcd(int a, int b) {
        while (b != 0) {
            int t = a % b;
            a = b;
            b = t;
        }
        return a;
    }
}
