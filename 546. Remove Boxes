class Solution {
    private int[][][] dp;

    public int removeBoxes(int[] boxes) {
        int n = boxes.length;
        dp = new int[n][n][n];
        return solve(boxes, 0, n - 1, 0);
    }

    private int solve(int[] boxes, int l, int r, int k) {
        if (l > r) return 0;

        if (dp[l][r][k] != 0)
            return dp[l][r][k];

        // Merge consecutive boxes of the same color at the end
        while (r > l && boxes[r] == boxes[r - 1]) {
            r--;
            k++;
        }

        // Remove the current group immediately
        int ans = solve(boxes, l, r - 1, 0) + (k + 1) * (k + 1);

        // Try to merge with same-colored boxes earlier
        for (int i = l; i < r; i++) {
            if (boxes[i] == boxes[r]) {
                ans = Math.max(
                    ans,
                    solve(boxes, l, i, k + 1) +
                    solve(boxes, i + 1, r - 1, 0)
                );
            }
        }

        return dp[l][r][k] = ans;
    }
}
