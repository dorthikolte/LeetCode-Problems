class Solution {
    private int[][][] dp;

    public int removeBoxes(int[] boxes) {
        int n = boxes.length;
        dp = new int[n][n][n];
        return dfs(boxes, 0, n - 1, 0);
    }

    private int dfs(int[] boxes, int l, int r, int k) {
        if (l > r) return 0;

        // canonicalize state
        while (r > l && boxes[r] == boxes[r - 1]) {
            r--;
            k++;
        }

        if (dp[l][r][k] != 0)
            return dp[l][r][k];

        int ans = dfs(boxes, l, r - 1, 0) + (k + 1) * (k + 1);

        for (int i = l; i < r; i++) {
            if (boxes[i] == boxes[r]) {
                ans = Math.max(ans,
                        dfs(boxes, l, i, k + 1)
                      + dfs(boxes, i + 1, r - 1, 0));
            }
        }

        return dp[l][r][k] = ans;
    }
}
