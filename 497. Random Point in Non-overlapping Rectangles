import java.util.*;

class Solution {

    int[][] rects;
    int[] prefix;
    int total;
    Random rand;

    public Solution(int[][] rects) {
        this.rects = rects;
        this.rand = new Random();
        
        prefix = new int[rects.length];
        total = 0;
        
        for (int i = 0; i < rects.length; i++) {
            int[] r = rects[i];
            int count = (r[2] - r[0] + 1) * (r[3] - r[1] + 1);
            total += count;
            prefix[i] = total;
        }
    }
    
    public int[] pick() {
        int target = rand.nextInt(total) + 1;
        
        // Binary search to find rectangle
        int left = 0, right = prefix.length - 1;
        while (left < right) {
            int mid = left + (right - left) / 2;
            if (prefix[mid] < target) left = mid + 1;
            else right = mid;
        }
        
        int[] r = rects[left];
        
        int x = r[0] + rand.nextInt(r[2] - r[0] + 1);
        int y = r[1] + rand.nextInt(r[3] - r[1] + 1);
        
        return new int[]{x, y};
    }
}
